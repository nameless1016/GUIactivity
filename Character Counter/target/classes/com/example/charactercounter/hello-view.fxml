<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.charactercounter.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <TextArea id="messageTextArea" fx:id="messageTextArea" prefHeight="200.0" prefWidth="200.0" />
      <HBox prefHeight="0.0" prefWidth="200.0">
         <children>
            <Label text="Enter Character: " />
            <TextField id="characterTextField" fx:id="characterTextField" />
         </children>
      </HBox>
      <Button id="countButton" fx:id="countButton" mnemonicParsing="false" onAction="#setCountButtonClick" text="Count" />
      <Label id="countLabel" fx:id="countLabel" layoutX="116.0" layoutY="295.0" text="Count:" />
   </children>
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
</VBox>
